  "ConnectionStrings": {
    "DefaultConnection": "Server=db.bqtbimefbeipvaabfper.supabase.co;Port=5432;Database=postgres;User Id=postgres;Password=Memo@356000;SSL Mode=Require;Trust Server Certificate=true"
  },
  "Jwt": {
    "Key": "SuperSecretKeyForTaskManagementAPI2026ChangeThisNow1234567890!",
    "Issuer": "TaskManagementAPI",
    "Audience": "TaskManagementAPI",
    "ExpirationMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Error",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss} [{Level:u3}] {RequestId} {UserId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] ReqId={RequestId} User={UserId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/audit-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 90,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [AUDIT] {Message:lj}{NewLine}",
          "filter": {
            "ByIncludingOnly": "IsAuditEvent = true"
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId"
    ],
    "Destructure": [
      {
        "Name": "ToMaximumDepth",
        "Args": { "maximumDestructuringDepth": 2 }
      },
      {
        "Name": "ToMaximumStringLength",
        "Args": { "maximumStringLength": 256 }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "Features": {
    "EnableSwagger": false,
    "EnableDetailedErrors": false
  }
}
